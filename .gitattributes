# Normalize line endings: auto-detect text files and use LF in the repository
* text=auto eol=lf

# Explicit text files
*.md       text eol=lf
*.txt      text eol=lf
*.py       text eol=lf
*.sh       text eol=lf
*.js       text eol=lf
*.ts       text eol=lf
*.json     text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.toml     text eol=lf
*.cfg      text eol=lf
*.ini      text eol=lf
.gitattributes text eol=lf
.gitignore     text eol=lf

# Shell scripts must keep LF endings
*.sh       text eol=lf

# Binary files (do not normalize or diff as text)
*.pptx     binary
*.ppt      binary
*.docx     binary
*.doc      binary
*.xlsx     binary
*.xls      binary
*.pdf      binary
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.zip      binary
*.gz       binary
*.tar      binary

# Collapse generated/vendored paths in diffs and language stats
*.lock        linguist-generated=true
